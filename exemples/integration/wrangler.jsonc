{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "cloudflare-pages-dynamic-ssr-test",
	"compatibility_date": "2026-04-12",
	"pages_build_output_dir": ".frame-master/build",
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "DYNAMIC_PAGE_KV",
			"id": "abc"
		}
	]
}
